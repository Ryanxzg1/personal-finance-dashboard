# Neon tech (Ganti dengan Connection String Neon Anda)
DATABASE_URL="postgresql://neondb_owner:your_random_password_here@ep-your-host-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Resend
RESEND_API_KEY=re_your_resend_api_key_here
REPORT_FROM_EMAIL="Buku Kas <reports@your-verified-domain.com>"
# Hanya dipakai di non-production untuk mengarahkan semua laporan ke satu inbox uji.
REPORT_RECIPIENT_OVERRIDE=tester@example.com

# Clerk Authentication (Ganti dengan API Keys Clerk Anda)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret_here

# Vercel Cron Secret
CRON_SECRET=your_long_random_cron_secret_here

# Database branch khusus integration test. Jangan gunakan database production.
TEST_DATABASE_URL="postgresql://test_owner:test_password@ep-test-pooler.ap-southeast-1.aws.neon.tech/test?sslmode=require"

# Origin API production, dipisahkan koma bila lebih dari satu.
ALLOWED_ORIGINS=https://your-domain.com

# Clerk Redirect Routes (Default kustom)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
